{
	"name": "@llamaindex/n8n-nodes-llamacloud",
	"version": "6.3.0",
	"description": "LlamaParse Platform integration with n8n",
	"license": "MIT",
	"homepage": "https://run-llama.github.io/n8n-llamacloud/",
	"keywords": [
		"n8n-community-node-package"
	],
	"author": {
		"email": "clelia@runllama.ai",
		"name": "Clelia Astra Bertelli"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/run-llama/n8n-llamacloud.git"
	},
	"scripts": {
		"build": "n8n-node build",
		"build:watch": "tsc --watch",
		"dev": "n8n-node dev",
		"lint": "n8n-node lint",
		"lint:fix": "n8n-node lint --fix",
		"release": "n8n-node release",
		"prepublishOnly": "n8n-node prerelease"
	},
	"files": [
		"dist"
	],
	"n8n": {
		"credentials": [
			"dist/credentials/LlamaParseApi.credentials.js"
		],
		"n8nNodesApiVersion": 1,
		"nodes": [
			"dist/nodes/LlamaParse/LlamaParsePlatform.node.js"
		]
	},
	"devDependencies": {
		"@changesets/cli": "^2.31.0",
		"@n8n/node-cli": "*",
		"eslint": "9.29.0",
		"prettier": "3.8.3",
		"release-it": "20.2.0",
		"typescript": "5.9.3"
	},
	"peerDependencies": {
		"n8n-workflow": "*"
	},
	"publishConfig": {
		"access": "public"
	}
}
