{
	"compilerOptions": {
		"strict": true,
		"module": "NodeNext",
		"moduleResolution": "nodenext",
		"target": "es2019",
		"lib": ["es2019", "es2020", "es2022.error", "dom", "dom.iterable"],
		"removeComments": true,
		"useUnknownInCatchVariables": false,
		"forceConsistentCasingInFileNames": true,
		"noImplicitAny": true,
		"noImplicitReturns": true,
		"noUnusedLocals": true,
		"strictNullChecks": true,
		"preserveConstEnums": true,
		"esModuleInterop": true,
		"allowSyntheticDefaultImports": true,
		"resolveJsonModule": true,
		"incremental": true,
		"declaration": true,
		"sourceMap": true,
		"skipLibCheck": true,
		"outDir": "./dist/",
		"allowJs": true,
	},
	"include": [
		"credentials/**/*",
		"nodes/LlamaParsePlatform/**/*.ts",
		"nodes/LlamaParsePlatform/**/*.json",
		"package.json",
	],
	"exclude": ["node_modules", "dist"],
}
